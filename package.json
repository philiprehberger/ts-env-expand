{
  "name": "@philiprehberger/env-expand",
  "version": "0.1.5",
  "description": "Interpolate variables within environment values",
  "keywords": [
    "env",
    "expand",
    "interpolate",
    "dotenv",
    "variable",
    "template",
    "environment"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-env-expand.git"
  },
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-env-expand/issues"
  },
  "homepage": "https://github.com/philiprehberger/ts-env-expand#readme",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
